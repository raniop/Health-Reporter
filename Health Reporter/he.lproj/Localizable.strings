"explanation.strain" = "כמה עמלת על הגוף (אימונים, פעילות). חשוב לאזן עם מנוחה.";
"explanation.efficiency" = "גרף המציג את יעילות ההתאוששות שלך לאורך הזמן. כל עמודה מייצגת יום. ירוק = התאוששות טובה, צהוב = בינונית, אדום = נמוכה.";
"explanation.bioSleep" = "ציון שינה 0–100 המשקלל משך שינה ואיכות (שינה עמוקה + REM). 80+ = מצוין, 60-80 = טוב, מתחת ל-60 = דורש שיפור.";
"explanation.bioTemp" = "הפרש טמפרטורת הגוף מהרגיל. שינוי גדול יכול להראות עייפות או חולי.";
"explanation.bioRhrOrTemp" = "דופק מנוחה (RHR) - מדד חשוב לכושר והתאוששות. ככל שנמוך יותר, הלב יעיל יותר. טווח בריא: 50-70 פעימות לדקה.";
"explanation.directives" = "הנחיות AI מבוססות על הנתונים שלך. עצור = הרגלים להפסיק. התחל = פעולות מומלצות. עקוב = דברים לשים לב אליהם.";
"explanation.insight" = "תובנה מהנתונים שלך – קשר בין דברים (למשל שינה ומדדים).";
"explanation.correlation" = "מדד קורלציה: עד כמה שני מדדים קשורים. 1.0 = קשר חזק חיובי, -1.0 = קשר הפוך, 0 = אין קשר.";
"explanation.pValue" = "P-Value - מדד סטטיסטי לאמינות. מתחת ל-0.05 = הקשר כנראה אמיתי ולא מקרי. ככל שנמוך יותר, כך אמין יותר.";
"explanation.sampleSize" = "מספר הימים שעליהם מבוססים הנתונים. 30+ ימים = תובנות אמינות יותר.";
"explanation.biometrics" = "סיכום מדדים ביומטריים: דופק מנוחה (RHR), שונות דופק (HRV), ועומס פיזי - להערכת מצב הבריאות.";
"explanation.focus" = "מוקדי התמקדות - תחומים שזוהו כחשובים לשיפור, מבוססים על ניתוח הנתונים שלך.";
"explanation.profileHeight" = "הגובה שלך מאפליקציית הבריאות של אפל. משמש לחישוב BMI ומדדים נוספים.";
"explanation.profileWeight" = "המשקל העדכני שלך מאפליקציית הבריאות. עדכון שוטף מאפשר מעקב מדויק.";
"explanation.highlights" = "דגשים יומיים: זמן במיטה, קצב נשימות בשינה, צעדים ומרחק - להבנת הפעילות היומית שלך.";
